     421/    E9BF :                     ; NXTSEC:
     422/    E9BF :                     ; if sector >= 27 - steps to next Track,
     423/    E9BF :                     ; updates SECTCNT, SofTRK, CWRDCNT, DWRDCNT
     424/    E9BF :                     ;------------------------------------------------
