     790/    ED41 :                     ; Calculate Tracks and Sectors of Sectors only Input
     791/    ED41 :                     ; Returns A as wanted Track
     792/    ED41 :                     ; Modifies SofTRK, SECTCNT
     793/    ED41 :                     ;------------------------------------------------
     794/    ED41 : 86 FF               CALCTRK         LDAA    #$FF     ; 
     795/    ED43 : 97 0A                               STAA    SofTRK   ; 
     796/    ED45 : 96 10                               LDAA    EXDSKSD  ;  Bit 7 high == SS
     797/    ED47 : 2A 25                               BPL     DUALSIDE ; 
     798/    ED49 : 96 01                               LDAA    STRSCTH  ; $0
     799/    ED4B : D6 02                               LDAB    STRSCTL  ; $D0
     800/    ED4D : 7C 00 0A            SE8EA           INC     SofTRK   ; is now at 0, increase to 1
     801/    ED50 : C0 D0                               SUBB    #$D0     ; 0xd0 = 8 tracks exactly
     802/    ED52 : 82 00                               SBCA    #$00     ; 
     803/    ED54 : 24 F7                               BCC     SE8EA    ; carry is clear, carry is set now
     804/    ED56 : CB D0                               ADDB    #$D0     ; D contains $0
     805/    ED58 : 96 0A                               LDAA    SofTRK   ; is 1
     806/    ED5A : 48                                  ASLA             ; 2
     807/    ED5B : 48                                  ASLA             ; 4
     808/    ED5C : 48                                  ASLA             ; SofTRK * 8
     809/    ED5D : 4A                                  DECA             ; 7
     810/    ED5E : 4C                  SE8FB           INCA             ; 8
     811/    ED5F : C0 1A                               SUBB    #$1A     ; B is 0
     812/    ED61 : 24 FB                               BCC     SE8FB    ; carry is set
     813/    ED63 : CB 1A                               ADDB    #$1A     ; B is 0 again
     814/    ED65 : D7 0A                               STAB    SofTRK   ; A is 8, SofTRK = 0
     815/    ED67 : DE 03                               LDX     NUMSCTH  ; A is Track wanted!
     816/    ED69 : DF 0B                               STX     SECTCNT  ; 
     817/    ED6B : D6 13                               LDAB    TRACKSAV ; 
     818/    ED6D : 39                                  RTS              ; 
