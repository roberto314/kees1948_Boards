     820/    ED6E : 96 01               DUALSIDE        LDAA    STRSCTH  ; $0
     821/    ED70 : D6 02                               LDAB    STRSCTL  ; $D0
     822/    ED72 : 7C 00 0A            DE8EA           INC     SofTRK   ; is now 0, increase to 1
     823/    ED75 : C0 D0                               SUBB    #$D0     ; $D0 is exactly 4 Tracks
     824/    ED77 : 82 00                               SBCA    #$00     ; 
